{
  "name": "zakai",
  "version": "0.1.0",
  "private": true,
  "description": "זכאי — consumer AI agent that finds inflated Israeli bills, acts on the customer's behalf, and charges a success fee only on documented savings.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && node scripts/prebuild-migrate.mjs && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.4",
    "@prisma/client": "^7.9.0",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3",
    "next": "^16.2.11",
    "next-intl": "^4.13.3",
    "nodemailer": "^9.0.3",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.5.4",
    "postcss": "^8.5.21",
    "prisma": "^7.9.0",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
