# --- Database ---
DATABASE_URL="postgresql://zakai@localhost:5433/zakai_dev?schema=public"

# --- Auth ---
# 32+ char secret used to sign session JWTs. Generate with: openssl rand -base64 48
AUTH_SECRET="dev-only-insecure-secret-change-me-please-32chars-min"

# --- AI (Anthropic) ---
# Server-side only. Never exposed to the browser.
# When unset, analysis/drafting endpoints return a clear "AI unavailable" error
# rather than fabricating results.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-5"

# --- Outbound email (outreach + notifications) ---
# When SMTP is unconfigured, messages are written to the Outbox table only
# (dev mode) and nothing leaves the system.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Zakai <no-reply@zakai.example>"

# --- SMS (ownership verification) ---
# When unset, the code is written to the Outbox only (dev mode) so the flow is
# fully testable without a real SMS provider.
SMS_PROVIDER="dev"          # dev | http
SMS_HTTP_URL=""             # generic HTTP SMS gateway endpoint
SMS_HTTP_TOKEN=""

# --- App ---
# Public base URL, used to build authorization-document verification links.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Contact addresses shown on the Trust/Security page and in fee emails.
NEXT_PUBLIC_SECURITY_EMAIL="security@zakai.example"
NEXT_PUBLIC_SUPPORT_EMAIL="support@zakai.example"

# --- Error monitoring (optional) ---
# When set (and @sentry/nextjs is installed) errors are forwarded to Sentry.
# When unset, errors are still logged to the host's Logs (Vercel).
SENTRY_DSN=""
